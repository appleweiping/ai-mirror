# ====================================================================
# ai-mirror server-side keys (ALL OPTIONAL)
# Set any of these in Vercel → Project → Settings → Environment Variables.
# If a provider's key is NOT set here, that provider works in BYOK mode:
# users paste their own key in the in-app Settings (stored only in their
# browser localStorage, never sent to us, only forwarded to the provider).
# ====================================================================

# --- Official provider keys (operator pays) ---
OPENAI_API_KEY=
# Optional: use a compatible gateway for the ChatGPT provider operator key.
OPENAI_BASE_URL=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
ARK_API_KEY=
QIANFAN_API_KEY=
HF_TOKEN=
# Optional: override the Hugging Face router for compatible self-hosted endpoints.
HF_BASE_URL=

# --- Optional OpenAI-compatible relay (one endpoint, many models) ---
# If set, providers flagged as relay-capable route here instead of the
# official upstream. Useful for serving "free" ChatGPT-style access.
# NOTE: third-party relays may violate provider ToS — use at your own risk.
RELAY_BASE_URL=
RELAY_API_KEY=
